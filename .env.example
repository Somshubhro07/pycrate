# ──────────────────────────────────────────────
# PyCrate Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── API Security ──────────────────────────────
# API key for authenticating dashboard requests.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PYCRATE_API_KEY=change-me-to-a-secure-random-string

# ── MongoDB Atlas ─────────────────────────────
# Connection URI from your Atlas dashboard.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
PYCRATE_MONGODB_URI=mongodb+srv://pycrate_user:password@cluster0.xxxxx.mongodb.net/pycrate?retryWrites=true&w=majority
PYCRATE_MONGODB_DB_NAME=pycrate

# ── Server ────────────────────────────────────
# Host and port for the FastAPI daemon.
PYCRATE_HOST=0.0.0.0
PYCRATE_PORT=8000

# ── CORS ──────────────────────────────────────
# Allowed origins for the dashboard. Comma-separated.
PYCRATE_CORS_ORIGINS=http://localhost:3000,https://pycrate.vercel.app

# ── Engine ────────────────────────────────────
# Base directory for container rootfs storage.
PYCRATE_DATA_DIR=/var/lib/pycrate

# Maximum number of concurrent containers (t2.micro has ~1GB RAM).
PYCRATE_MAX_CONTAINERS=4

# Alpine miniroot version to use as base image.
PYCRATE_ALPINE_VERSION=3.19

# ── Logging ───────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
PYCRATE_LOG_LEVEL=INFO
